FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y asterisk && rm -rf /var/lib/apt/lists/*
COPY services/telephony-service/asterisk-config/ /etc/asterisk/
COPY services/telephony-service/entrypoint-asterisk.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
EXPOSE 5060/udp 8088/tcp 10000-10100/udp
CMD ["/entrypoint.sh"]
