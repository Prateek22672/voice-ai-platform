############ Voice AI Platform — environment ############
# Copy to .env and fill. Comments say where each key comes from.

# ---- LLM (need at least one; conversation-service) ----
ANTHROPIC_API_KEY=            # console.anthropic.com -> API keys
OPENAI_API_KEY=               # platform.openai.com -> API keys
LLM_MODEL=claude-sonnet-4-6   # any litellm model string; local: ollama/llama3

# ---- Model downloads ----
HF_TOKEN=                     # huggingface.co/settings/tokens (needed for some gated models)

# ---- STT ----
WHISPER_MODEL=small           # dev CPU: tiny/base | GPU prod: large-v3 or distil-large-v3
WHISPER_DEVICE=auto           # auto|cuda|cpu
WHISPER_COMPUTE=default       # GPU: float16 | CPU: int8

# ---- TTS ----
TTS_BACKEND=espeak            # espeak (plumbing test) | kokoro | f5tts | cosyvoice | xtts
TTS_EXTRA=                    # pip extras baked into image, e.g.: kokoro soundfile

# ---- Telephony (Phase 2; portal.telnyx.com -> SIP connection + number) ----
TELNYX_API_KEY=
SIP_TRUNK_USER=
SIP_TRUNK_PASS=
SIP_DID_NUMBER=               # your purchased number, E.164: +1555...

# ---- Datastores (compose defaults fine for dev) ----
POSTGRES_URL=postgresql://voice:voice@postgres:5432/voiceai
REDIS_URL=redis://redis:6379/0
NATS_URL=nats://nats:4222
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ---- Auth ----
JWT_SECRET=change-me-in-prod
DEV_API_KEY=dev-test-key      # dev bypass key; REMOVE in production (create real keys via /admin/keys)
RATE_LIMIT_PER_MIN=300
